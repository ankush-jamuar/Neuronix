# Database Connections
# Used by Prisma to connect to the PostgreSQL instance.
DATABASE_URL="postgresql://postgres:password@localhost:5432/neuronix?schema=public"
# Used for direct connections if bypassing a transaction pooler (mostly Supabase).
DIRECT_URL="postgresql://postgres:password@localhost:5432/neuronix?schema=public"

# Server Config
# The port this Express server listens on.
PORT=5000

# Clerk Auth
# Used by Express middleware to verify token signatures issued by Clerk.
CLERK_SECRET_KEY="sk_test_..."

# AI APIs
# Groq is the primary fast LLM for the RAG chat.
GROQ_API_KEY="gsk_..."
# Fallback LLM (optional).
OPENAI_API_KEY="sk-..."

# Cloudinary
# Stores user files (PDFs/Images) uploaded via the client.
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Stripe Payments
# Manages user subscriptions to tier limits.
STRIPE_SECRET_KEY="sk_test_..."
